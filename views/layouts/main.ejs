<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | KenziemotoSport</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Poppins', sans-serif; }
        .bg-purple-gradient { background: linear-gradient(135deg, #7c3aed 0%, #4c1d95 100%); }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

    <!-- Navbar -->
    <nav class="bg-white shadow-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="text-2xl font-bold text-purple-700">Kenziemoto<span class="text-gray-800">Sport</span></a>
                </div>
                
                <div class="hidden md:flex space-x-8 items-center">
                    <a href="/" class="text-gray-600 hover:text-purple-700 font-medium">Home</a>
                    <a href="/products" class="text-gray-600 hover:text-purple-700 font-medium">Products</a>
                    <% if (user && user.role === 'admin') { %>
                        <a href="/admin/dashboard" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">Admin Dashboard</a>
                    <% } %>
                    
                    <% if (user) { %>
                        <div class="flex items-center space-x-4">
                            <a href="/cart" class="relative text-gray-600 hover:text-purple-700">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </a>
                            <a href="/orders" class="text-gray-600 hover:text-purple-700 font-medium">My Orders</a>
                            <a href="/auth/logout" class="text-red-500 hover:text-red-600 font-medium">Logout</a>
                            <span class="text-sm font-semibold text-purple-700 ml-2">Hi, <%= user.name %>!</span>
                        </div>
                    <% } else { %>
                        <div class="flex items-center space-x-4">
                            <a href="/auth/login" class="text-gray-600 hover:text-purple-700 font-medium">Login</a>
                            <a href="/auth/register" class="px-5 py-2 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition shadow-md">Register</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-12 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <h3 class="text-2xl font-bold mb-4">KenziemotoSport</h3>
                    <p class="text-gray-400">Solusi terbaik sparepart motor Anda. Berkualitas, Terpercaya, dan Terjamin.</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Quick Links</h4>
                    <ul class="space-y-2">
                        <li><a href="/" class="text-gray-400 hover:text-white">Home</a></li>
                        <li><a href="/products" class="text-gray-400 hover:text-white">All Products</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Contacts</h4>
                    <p class="text-gray-400">Email: kenziesport@gmail.com</p>
                    <p class="text-gray-400">WA: +62 812-3456-7890</p>
                </div>
            </div>
            <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
                <p>&copy; <%= new Date().getFullYear() %> KenziemotoSport. All rights reserved.</p>
            </div>
        </div>
    </footer>

</body>
</html>
