<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-16">
        <h1 class="text-4xl font-extrabold text-gray-800 uppercase tracking-widest leading-tight">Proses <br> <span class="text-orange-600">Pesanan Masuk</span></h1>
        <p class="text-gray-400 mt-2 font-bold uppercase text-[10px] tracking-widest">Verifikasi Bayar Dan Kirim Barang.</p>
    </div>

    <div class="bg-white rounded-[40px] shadow-2xl border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-900 text-white">
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">ID Order</th>
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">Nama Pembeli</th>
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">Total Harga</th>
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">Status</th>
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">Tanggal</th>
                        <th class="px-10 py-8 font-black uppercase tracking-widest text-xs">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% orders.forEach(o => { %>
                        <tr class="group hover:bg-orange-50 transition duration-300">
                            <td class="px-10 py-8">
                                <span class="text-lg font-black text-gray-800 uppercase tracking-tight">#<%= o.id %></span>
                            </td>
                            <td class="px-10 py-8">
                                <h3 class="text-lg font-extrabold text-gray-800 italic uppercase tracking-tight"><%= o.user_name %></h3>
                            </td>
                            <td class="px-10 py-8">
                                <p class="text-xl font-black text-gray-900 tracking-tighter">Rp <%= parseFloat(o.total_price).toLocaleString('id-ID') %></p>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <span class="px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm inline-block
                                    <%= o.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : '' %>
                                    <%= o.status === 'paid' ? 'bg-blue-100 text-blue-700' : '' %>
                                    <%= o.status === 'shipped' ? 'bg-purple-100 text-purple-700' : '' %>
                                    <%= o.status === 'completed' ? 'bg-green-100 text-green-700' : '' %>
                                    <%= o.status === 'rejected' ? 'bg-red-100 text-red-700' : '' %>
                                ">
                                    <%= o.status %>
                                </span>
                            </td>
                            <td class="px-10 py-8">
                                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest"><%= new Date(o.created_at).toLocaleDateString('id-ID') %></p>
                            </td>
                            <td class="px-10 py-8">
                                <a href="/admin/orders/<%= o.id %>" class="px-8 py-3 bg-gray-900 text-white rounded-xl font-black uppercase tracking-widest text-[10px] shadow-sm hover:shadow-xl hover:bg-orange-600 transition">Detail Order</a>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (orders.length === 0) { %>
                        <tr>
                            <td colspan="6" class="py-20 text-center text-gray-400 font-bold uppercase tracking-widest">Belum ada pesanan yang masuk.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
