<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12 flex justify-between items-center">
        <div>
            <h1 class="text-4xl font-extrabold text-gray-800 uppercase tracking-widest leading-tight">Proses <br> <span class="text-orange-600">Pesanan Pelanggan</span></h1>
            <p class="text-gray-400 mt-2 font-bold uppercase text-[10px] tracking-widest">ORDER ID: #<%= order.id %></p>
        </div>
        <div class="text-right">
            <span class="px-10 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest shadow-2xl border-4 
                <%= order.status === 'pending' ? 'bg-yellow-101 border-yellow-500 text-yellow-700' : '' %>
                <%= order.status === 'paid' ? 'bg-blue-101 border-blue-500 text-blue-700' : '' %>
                <%= order.status === 'shipped' ? 'bg-purple-101 border-purple-500 text-purple-700' : '' %>
                <%= order.status === 'completed' ? 'bg-green-101 border-green-500 text-green-700' : '' %>
                <%= order.status === 'rejected' ? 'bg-red-101 border-red-500 text-red-700' : '' %>
            ">
                Status Saat Ini: <%= order.status %>
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="space-y-12">
            <div class="bg-white rounded-[40px] shadow-2xl border border-gray-100 p-12">
                <h3 class="text-xl font-black text-gray-800 mb-10 uppercase tracking-widest border-b border-gray-100 pb-4">Bukti Pembayaran</h3>
                <% if (payment) { %>
                    <div class="bg-gray-100 rounded-3xl overflow-hidden shadow-2xl border border-gray-100 p-4 relative group">
                        <img src="/uploads/payments/<%= payment.proof %>" alt="Bukti Transfer" class="w-full h-auto cursor-zoom-in group-hover:scale-105 transition duration-700" onclick="window.open('/uploads/payments/<%= payment.proof %>')">
                    </div>
                    <% if (order.status === 'pending') { %>
                        <div class="flex gap-4 mt-8">
                            <form action="/admin/orders/confirm/<%= order.id %>" method="POST" class="flex-1">
                                <button type="submit" class="w-full py-6 bg-green-600 text-white rounded-2xl font-black uppercase tracking-widest text-sm shadow-xl hover:bg-green-700 transition hover:scale-105 active:scale-95">CONFIRM PAYMENT</button>
                            </form>
                            <form action="/admin/orders/reject/<%= order.id %>" method="POST" class="flex-1">
                                <button type="submit" class="w-full py-6 bg-red-600 text-white rounded-2xl font-black uppercase tracking-widest text-sm shadow-xl hover:bg-red-700 transition hover:scale-105 active:scale-95">REJECT PAYMENT</button>
                            </form>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="p-20 text-center border-4 border-dashed border-gray-100 rounded-[40px]">
                        <p class="text-gray-300 font-black uppercase tracking-widest">User Belum Upload Bukti Pembayaran.</p>
                    </div>
                <% } %>
            </div>

            <div class="bg-white rounded-[40px] shadow-2xl border border-gray-100 p-12">
                <h3 class="text-xl font-black text-gray-800 mb-10 uppercase tracking-widest border-b border-gray-100 pb-4">Detail Pengiriman</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-2">Nama Penerima</p>
                        <p class="text-xl font-extrabold text-gray-800 tracking-tight uppercase italic"><%= order.user_name %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-2">Email Pelanggan</p>
                        <p class="text-lg font-bold text-gray-700 uppercase"><%= order.user_email %></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-12">
            <div class="bg-gray-900 text-white rounded-[40px] shadow-2xl p-12 overflow-hidden relative">
                <div class="absolute top-0 right-0 w-64 h-64 bg-orange-600 blur-3xl opacity-10 -mr-32 -mt-32"></div>
                <h3 class="text-xl font-black mb-10 uppercase tracking-widest border-b border-gray-800 pb-4">Tindakan Admin</h3>
                
                <form action="/admin/orders/status/<%= order.id %>" method="POST" class="space-y-10">
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Ubah Status Pengiriman</label>
                        <select name="status" class="w-full bg-gray-800 border-b-4 border-gray-700 focus:border-orange-500 focus:outline-none transition-all py-6 px-8 rounded-t-3xl font-black uppercase tracking-widest text-xs text-white shadow-inner appearance-none">
                            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>PENDING</option>
                            <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>PAID</option>
                            <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>SHIPPED</option>
                            <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>COMPLETED</option>
                            <option value="rejected" <%= order.status === 'rejected' ? 'selected' : '' %>>REJECTED</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full py-8 bg-orange-600 text-white rounded-[40px] font-black uppercase tracking-widest shadow-2xl hover:bg-orange-700 transition hover:scale-105 active:scale-95 text-lg">UPDATE PESANAN</button>
                    <div class="pt-8 text-center">
                        <a href="/admin/orders" class="text-xs font-black text-gray-500 uppercase tracking-widest hover:text-white transition">Kembali ke Daftar Pesanan</a>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-[40px] shadow-2xl border border-gray-100 p-12">
                <h3 class="text-xl font-black text-gray-800 mb-10 uppercase tracking-widest border-b border-gray-100 pb-4">Ringkasan Barang</h3>
                <div class="space-y-8 max-h-[400px] overflow-y-auto pr-4 scrollbar-thin scrollbar-thumb-gray-100">
                    <% items.forEach(item => { %>
                        <div class="flex flex-col gap-2 pb-6 border-b border-gray-50 last:border-0 last:pb-0">
                            <span class="text-lg font-extrabold text-gray-800 uppercase tracking-tight"><%= item.name %></span>
                            <div class="flex justify-between items-center bg-gray-50 p-4 rounded-2xl">
                                <span class="text-xs text-gray-400 font-bold uppercase tracking-widest italic tracking-tighter"><%= item.qty %> x Rp <%= parseFloat(item.price).toLocaleString('id-ID') %></span>
                                <span class="text-lg font-black text-gray-900">Rp <%= (parseFloat(item.price) * item.qty).toLocaleString('id-ID') %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <div class="mt-12 pt-10 border-t border-gray-100 flex justify-between items-center">
                    <span class="text-xl font-black text-gray-400 uppercase tracking-tighter">Total Yang Dibayar</span>
                    <span class="text-3xl font-black text-gray-900 tracking-tighter">Rp <%= parseFloat(order.total_price).toLocaleString('id-ID') %></span>
                </div>
            </div>
        </div>
    </div>
</div>
