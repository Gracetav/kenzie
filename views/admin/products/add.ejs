<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-16">
        <h1 class="text-4xl font-extrabold text-gray-800 uppercase tracking-widest leading-tight">Master <br> <span class="text-purple-600">Product Entry</span></h1>
        <p class="text-gray-400 mt-2 font-bold uppercase text-[10px] tracking-widest">Tambahkan Koleksi Baru Anda.</p>
    </div>

    <div class="bg-white rounded-[40px] shadow-2xl border border-gray-100 p-16 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-64 h-64 bg-purple-600 blur-3xl opacity-5 -ml-32 -mt-32"></div>
        <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="space-y-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
                <div class="space-y-8">
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Nama Produk</label>
                        <input type="text" name="name" required class="w-full bg-gray-50 border-b-4 border-gray-200 focus:border-purple-600 focus:outline-none transition-all py-4 px-6 rounded-t-2xl font-bold text-gray-800 text-xl tracking-tighter shadow-inner" placeholder="E.g. Kampas Rem Depan">
                    </div>
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Harga (Rp)</label>
                            <input type="number" name="price" required class="w-full bg-gray-50 border-b-4 border-gray-200 focus:border-purple-600 focus:outline-none transition-all py-4 px-6 rounded-t-2xl font-black text-gray-900 text-xl tracking-tighter shadow-inner" placeholder="150000">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Stok</label>
                            <input type="number" name="stock" required class="w-full bg-gray-50 border-b-4 border-gray-200 focus:border-purple-600 focus:outline-none transition-all py-4 px-6 rounded-t-2xl font-black text-gray-900 text-xl tracking-tighter shadow-inner" placeholder="50">
                        </div>
                    </div>
                </div>
                
                <div class="space-y-8">
                    <div>
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Deskripsi Produk</label>
                        <textarea name="description" rows="5" class="w-full bg-gray-50 border-b-4 border-gray-200 focus:border-purple-600 focus:outline-none transition-all py-4 px-6 rounded-t-2xl font-medium text-gray-600 leading-relaxed shadow-inner" placeholder="Tuliskan spesifikasi produk..."></textarea>
                    </div>
                </div>
            </div>

            <div class="border-t border-gray-50 pt-16 grid grid-cols-1 md:grid-cols-3 items-center gap-16">
                <div class="md:col-span-2">
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-6">Upload Foto Produk</label>
                    <input type="file" name="image" class="w-full bg-gray-50 border-2 border-dashed border-gray-200 rounded-3xl p-10 text-gray-500 font-bold uppercase tracking-widest text-[10px] file:mr-10 file:py-4 file:px-10 file:rounded-2xl file:border-0 file:text-xs file:font-black file:bg-gray-900 file:text-white hover:file:bg-purple-600 file:transition-all cursor-pointer">
                </div>
                <div class="md:col-span-1 pt-12">
                   <button type="submit" class="w-full py-8 bg-purple-600 text-white rounded-3xl font-black uppercase tracking-widest shadow-2xl hover:bg-purple-700 transition hover:scale-105 active:scale-95 text-lg">POSTING PRODUCT</button>
                   <a href="/admin/products" class="w-full text-center block mt-6 text-gray-400 font-bold uppercase tracking-widest text-[10px] hover:text-red-500 transition">Batal dan Kembali</a>
                </div>
            </div>
        </form>
    </div>
</div>
