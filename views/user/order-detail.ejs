<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12 flex justify-between items-center">
        <div>
            <h1 class="text-4xl font-extrabold text-gray-800 uppercase tracking-widest">Detail <span class="text-purple-600">Pesanan</span></h1>
            <p class="text-gray-500 mt-2 font-medium">Order Number: #<%= order.id %></p>
        </div>
        <div class="text-right">
            <span class="px-8 py-3 rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl border-2 
                <%= order.status === 'pending' ? 'bg-yellow-101 border-yellow-400 text-yellow-700' : '' %>
                <%= order.status === 'paid' ? 'bg-blue-101 border-blue-400 text-blue-700' : '' %>
                <%= order.status === 'shipped' ? 'bg-purple-101 border-purple-400 text-purple-700' : '' %>
                <%= order.status === 'completed' ? 'bg-green-101 border-green-400 text-green-700' : '' %>
                <%= order.status === 'rejected' ? 'bg-red-101 border-red-400 text-red-700' : '' %>
            ">
                Status: <%= order.status %>
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <div class="lg:col-span-2">
            <div class="bg-white rounded-3xl p-10 shadow-2xl border border-gray-100 mb-12">
                <h3 class="text-2xl font-black text-gray-800 mb-10 uppercase tracking-widest border-b border-gray-100 pb-4">Isi Pesanan</h3>
                <div class="space-y-8">
                    <% items.forEach(item => { %>
                        <div class="flex items-center space-x-8 pb-8 border-b border-gray-50 last:border-0 last:pb-0">
                            <div class="w-24 h-24 bg-gray-50 rounded-2xl overflow-hidden flex-shrink-0 border border-gray-50 p-2">
                                <% if (item.image) { %>
                                    <img src="/uploads/products/<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-contain">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No Image</div>
                                <% } %>
                            </div>
                            <div class="flex-grow">
                                <h4 class="text-lg font-bold text-gray-800 uppercase tracking-wide"><%= item.name %></h4>
                                <p class="text-gray-400 font-bold uppercase text-[10px] mt-1 tracking-widest">Qty: <%= item.qty %> x Rp <%= parseFloat(item.price).toLocaleString('id-ID') %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-xl font-black text-purple-700">Rp <%= (parseFloat(item.price) * item.qty).toLocaleString('id-ID') %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <div class="mt-12 pt-10 border-t border-gray-100 flex justify-between items-center bg-gray-50 -mx-10 -mb-10 p-10 rounded-b-3xl">
                    <span class="text-2xl font-black text-gray-400 uppercase tracking-tighter">Grand Total</span>
                    <span class="text-4xl font-black text-gray-900 tracking-tighter">Rp <%= parseFloat(order.total_price).toLocaleString('id-ID') %></span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-white rounded-3xl p-10 shadow-2xl border border-gray-100 sticky top-24 overflow-hidden relative">
                <div class="absolute top-0 right-0 w-24 h-24 bg-purple-600 blur-3xl opacity-20 -mr-12 -mt-12"></div>
                <h3 class="text-2xl font-black text-gray-800 mb-8 uppercase tracking-widest relative">Pembayaran</h3>
                
                <% if (!payment) { %>
                    <div class="bg-purple-50 p-6 rounded-2xl mb-8 border border-purple-100 text-purple-700 text-sm leading-relaxed font-medium">
                        Silakan transfer total pembayaran ke:<br>
                        <span class="font-black text-lg block my-3">BCA: 123456789 (KenziemotoSport)</span>
                        Setelah transfer, silakan upload bukti di bawah.
                    </div>
                    <form action="/orders/upload-proof" method="POST" enctype="multipart/form-data" class="space-y-6">
                        <input type="hidden" name="order_id" value="<%= order.id %>">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Upload Bukti Transfer</label>
                            <input type="file" name="proof" required class="w-full bg-gray-50 border-2 border-dashed border-gray-200 rounded-2xl p-6 text-sm text-gray-500 font-medium file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-purple-600 file:text-white hover:file:bg-purple-700 cursor-pointer">
                        </div>
                        <button type="submit" class="w-full py-5 bg-purple-600 text-white rounded-2xl font-bold hover:bg-purple-700 shadow-xl transition-all uppercase tracking-widest text-sm">Upload Bukti Sekarang</button>
                    </form>
                <% } else { %>
                    <div class="space-y-8">
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Status Bukti</p>
                            <span class="px-5 py-2 bg-green-100 text-green-700 text-[10px] font-black uppercase tracking-widest rounded-full">Bukti Sudah Diupload</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Preview Bukti</p>
                            <div class="w-full h-80 bg-gray-100 rounded-3xl overflow-hidden shadow-inner border border-gray-50 p-2">
                                <img src="/uploads/payments/<%= payment.proof %>" alt="Bukti Transfer" class="w-full h-full object-contain cursor-zoom-in" onclick="window.open('/uploads/payments/<%= payment.proof %>')">
                            </div>
                        </div>
                        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 text-xs text-gray-500 font-medium leading-relaxed italic">
                            Tim kami akan memverifikasi pembayaran Anda segera. Terima kasih sudah belanja di KenziemotoSport!
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
