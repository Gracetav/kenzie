<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12">
        <h1 class="text-4xl font-extrabold text-gray-800">Daftar <span class="text-purple-600">Pesanan Saya</span></h1>
        <p class="text-gray-500 mt-2 font-medium">Lacak status pesanan sparepart motor Anda di sini.</p>
    </div>

    <% if (orders.length === 0) { %>
        <div class="bg-white p-20 rounded-3xl shadow-2xl text-center border-2 border-dashed border-gray-200">
            <h2 class="text-3xl font-bold text-gray-800 mb-4 uppercase tracking-widest">Belum Ada Pesanan!</h2>
            <p class="text-gray-500 text-lg mb-10">Pesanan Anda akan muncul di sini setelah checkout.</p>
            <a href="/products" class="inline-block px-12 py-5 bg-purple-600 text-white rounded-2xl font-bold hover:bg-purple-700 transition shadow-xl uppercase tracking-widest">Mulai Belanja</a>
        </div>
    <% } else { %>
        <div class="space-y-6">
            <% orders.forEach(order => { %>
                <div class="bg-white rounded-3xl p-8 shadow-xl border border-gray-100 flex flex-col md:flex-row items-center justify-between gap-12 transition hover:shadow-2xl hover:scale-[1.01] duration-300">
                    <div class="flex items-center space-x-8 w-full md:w-auto">
                        <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center text-purple-700">
                            <span class="text-2xl font-bold">#<%= order.id %></span>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Tanggal Pesanan</p>
                            <h3 class="text-xl font-extrabold text-gray-800"><%= new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></h3>
                            <p class="text-purple-600 font-bold mt-1 uppercase text-xs tracking-widest">Total Bayar: Rp <%= parseFloat(order.total_price).toLocaleString('id-ID') %></p>
                        </div>
                    </div>
                    
                    <div class="flex items-center space-x-12 w-full md:w-auto">
                        <div class="text-center">
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-2">Status Pesanan</p>
                            <span class="px-6 py-2 rounded-full text-xs font-black uppercase tracking-widest inline-block shadow-sm 
                                <%= order.status === 'pending' ? 'bg-yellow-100 text-yellow-700 border-2 border-yellow-300' : '' %>
                                <%= order.status === 'paid' ? 'bg-blue-100 text-blue-700 border-2 border-blue-300' : '' %>
                                <%= order.status === 'shipped' ? 'bg-purple-100 text-purple-700 border-2 border-purple-300' : '' %>
                                <%= order.status === 'completed' ? 'bg-green-100 text-green-700 border-2 border-green-300' : '' %>
                                <%= order.status === 'rejected' ? 'bg-red-100 text-red-700 border-2 border-red-300' : '' %>
                            ">
                                <%= order.status %>
                            </span>
                        </div>
                        <a href="/orders/<%= order.id %>" class="flex-grow md:flex-none text-center px-10 py-4 bg-gray-900 text-white rounded-2xl font-bold hover:bg-gray-800 transition shadow-lg uppercase tracking-widest text-sm">Lihat Detail</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
